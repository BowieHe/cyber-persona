{
  "name": "cyber-bowie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && npm run build:assets --workspaces --if-present",
    "check": "tsc -b tsconfig.json && npm run check:assets --workspaces --if-present",
    "test": "node --import tsx --test packages/**/*.test.ts",
    "dev": "node --use-env-proxy packages/pi-coding-agent/dist/index.js",
    "agent": "node --use-env-proxy packages/pi-coding-agent/dist/index.js",
    "server": "node --use-env-proxy packages/pi-server/dist/index.js",
    "web": "node --use-env-proxy packages/pi-server/dist/index.js"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^16.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@types/node": "^24.5.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.1.5"
  }
}
